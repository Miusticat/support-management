{
  "name": "support-management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:deploy:if-configured": "node -e \"if (!process.env.DATABASE_URL) { console.log('Skipping prisma migrate deploy: DATABASE_URL is not set'); process.exit(0); } try { require('child_process').execSync('npx prisma migrate deploy', { stdio: 'inherit' }); } catch (err) { console.warn('⚠ Warning: Prisma migrations failed. Build will continue, but ensure database is synced before runtime. Error:', err.message); }\"",
    "vercel-build": "npm run db:migrate:deploy:if-configured && npm run build"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "file-saver": "^2.0.5",
    "html-to-image": "^1.11.11",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.577.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

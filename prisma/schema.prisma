generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  membership    DiscordMembership?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DiscordMembership {
  id          String   @id @default(cuid())
  userId      String   @unique
  guildId     String
  permissions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model StaffSanction {
  id                    String   @id @default(cuid())
  supportDiscordId       String
  supportName            String
  supportPcuLink         String?
  adminDiscordId         String?
  adminName              String
  fecha                  String
  policyCategory         String?
  policyFault            String?
  motivo                 String
  categorias             String[]
  pruebas                String?
  requestedSanction      String
  appliedSanction        String
  levelLabel             String?
  previousAdvertencias   Int      @default(0)
  previousWarnIntermedios Int     @default(0)
  previousWarnGraves     Int      @default(0)
  accumulationNote       String?
  observaciones          String?
  createdAt              DateTime @default(now())

  @@index([supportDiscordId])
  @@index([createdAt])
}

model StaffPositivePoints {
  id                    String   @id @default(cuid())
  supportDiscordId       String
  supportName            String
  supportPcuLink         String?
  adminDiscordId         String?
  adminName              String
  fecha                  String
  pointType              String
  pointValue             Float
  justificacion          String
  evidencia              String?
  categorias             String[]
  observaciones          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([supportDiscordId])
  @@index([createdAt])
}

model SanctionPolicyCategory {
  id         String                   @id @default(cuid())
  name       String                   @unique
  sortOrder  Int                      @default(0)
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  infractions SanctionPolicyInfraction[]

  @@index([sortOrder])
}

// ─── Stats: ported from support-tracker ──────────────────────

model Ticket {
  id          Int       @id
  username    String
  character   String
  request     String
  submittedAt DateTime  @map("submitted_at") @db.Timestamptz(6)
  handler     String?
  importedBy  Int?      @map("imported_by")
  importedAt  DateTime  @default(now()) @map("imported_at") @db.Timestamptz(6)
  categoryId  Int?      @map("category_id")
  category    TicketCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([submittedAt])
  @@index([handler])
  @@index([categoryId])
  @@map("tickets")
}

model TicketCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  color       String
  icon        String
  description String?
  keywords    String   @default("")
  weight      Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tickets     Ticket[]

  @@map("ticket_categories")
}

model SupportMember {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("support_members")
}

model TicketAuditLog {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id")
  username  String
  action    String
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([action])
  @@index([username])
  @@map("ticket_audit_log")
}

model SanctionPolicyInfraction {
  id          String                @id @default(cuid())
  categoryId  String
  category    SanctionPolicyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fault       String
  sanction    String
  tags        String[]
  sortOrder   Int                   @default(0)
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([categoryId])
  @@index([sortOrder])
}

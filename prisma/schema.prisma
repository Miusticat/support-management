generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  membership    DiscordMembership?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DiscordMembership {
  id          String   @id @default(cuid())
  userId      String   @unique
  guildId     String
  permissions String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guildId])
}

model StaffSanction {
  id                    String   @id @default(cuid())
  supportDiscordId       String
  supportName            String
  supportPcuLink         String?
  adminDiscordId         String?
  adminName              String
  fecha                  String
  policyCategory         String?
  policyFault            String?
  motivo                 String
  categorias             String[]
  pruebas                String?
  requestedSanction      String
  appliedSanction        String
  levelLabel             String?
  previousAdvertencias   Int      @default(0)
  previousWarnIntermedios Int     @default(0)
  previousWarnGraves     Int      @default(0)
  accumulationNote       String?
  observaciones          String?
  createdAt              DateTime @default(now())

  @@index([supportDiscordId])
  @@index([createdAt])
}

model StaffPositivePoints {
  id                    String   @id @default(cuid())
  supportDiscordId       String
  supportName            String
  supportPcuLink         String?
  adminDiscordId         String?
  adminName              String
  fecha                  String
  pointType              String
  pointValue             Float
  justificacion          String
  evidencia              String?
  categorias             String[]
  observaciones          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([supportDiscordId])
  @@index([createdAt])
}

model SanctionPolicyCategory {
  id         String                   @id @default(cuid())
  name       String                   @unique
  sortOrder  Int                      @default(0)
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  infractions SanctionPolicyInfraction[]

  @@index([sortOrder])
}

model SanctionPolicyInfraction {
  id          String                @id @default(cuid())
  categoryId  String
  category    SanctionPolicyCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fault       String
  sanction    String
  tags        String[]
  sortOrder   Int                   @default(0)
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([categoryId])
  @@index([sortOrder])
}
